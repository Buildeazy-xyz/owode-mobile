{
  "expo": {
    "name": "OWODE Alajo",
    "slug": "owode-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d47a1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.owodealajo.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "OWODE uses Face ID to securely unlock your account",
        "NSCameraUsageDescription": "OWODE uses your camera for face verification"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d47a1"
      },
      "package": "com.owodealajo.mobile",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0d47a1"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9a3481c5-e161-47e5-844e-d608cbe23738"
      }
    }
  }
}